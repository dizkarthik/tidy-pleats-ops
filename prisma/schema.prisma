generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReferralSource {
  INSTAGRAM
  WHATSAPP_STATUS
  FACEBOOK
  GOOGLE
  WALK_IN
  OTHER
}

enum ReferralKind {
  SOCIAL_MEDIA
  EXISTING_CUSTOMER
}

enum CustomerSize {
  S
  M
  L
  XL
  XXL
}

enum UserRole {
  OWNER
  SPOUSE
}

enum OrderType {
  SINGLE
  MULTI
}

enum DeliveryType {
  ONE_TIME
  MULTIPLE
}

enum DiscountType {
  PERCENT
  RUPEE
}

enum AdvancePaymentMethod {
  CASH
  UPI
}

enum PickupDrop {
  NO
  PICKUP
  DROP
  PICKUP_AND_DROP
}

enum OrderItemStatus {
  BOOKED
  COLLECTED
  IN_PROGRESS
  QUALITY_CHECK
  READY
  DELIVERED
  CANCELLED
}

model User {
  id           String    @id @default(cuid())
  name         String
  username     String    @unique
  passwordHash String
  role         UserRole
  sessions     Session[]
  statusChanges OrderItemStatusHistory[]
  createdAt    DateTime  @default(now())

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Customer {
  id                   String         @id @default(cuid())
  name                 String
  phoneNumber          String         @unique
  location             String?
  address              String?
  birthdayDate         DateTime?      @db.Date
  size                 CustomerSize?
  referralKind         ReferralKind
  referralSource       ReferralSource?
  referredByCustomerId String?
  notes                String?
  dateAdded            DateTime       @default(now())
  orders               Order[]

  // Referred-by is a linked customer record, not free text, so referral counts
  // remain accurate and typo-proof in later order/offer phases.
  referredByCustomer Customer?  @relation("CustomerReferrals", fields: [referredByCustomerId], references: [id], onDelete: SetNull)
  referrals          Customer[] @relation("CustomerReferrals")

  @@index([name])
  @@index([phoneNumber])
  @@index([location])
  @@index([referredByCustomerId])
  @@map("customers")
}

model Order {
  id                   Int                  @id @default(autoincrement())
  customerId           String
  orderDate            DateTime             @default(now())
  orderType            OrderType
  deliveryType         DeliveryType
  discountValue        Decimal              @default(0) @db.Decimal(10, 2)
  discountType         DiscountType         @default(RUPEE)
  advancePaid          Decimal              @default(0) @db.Decimal(10, 2)
  advancePaymentMethod AdvancePaymentMethod @default(CASH)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  // Single and Multi orders share one schema. Single is simply one item with
  // deliveryType stored as ONE_TIME, which keeps later reporting consistent.
  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    OrderItem[]

  @@index([customerId])
  @@index([orderDate])
  @@index([orderType])
  @@map("orders")
}

model OrderItem {
  id                 String     @id @default(cuid())
  orderId            Int
  sareeNumber        Int
  palluPleats        Int
  centerPleats       Int
  photoUrl           String?
  sareeNotes         String?
  damageNoticed      Boolean    @default(false)
  damageNotes        String?
  informedToCustomer Boolean    @default(false)
  price              Decimal    @db.Decimal(10, 2)
  neededBy           DateTime   @db.Date
  pickupDrop         PickupDrop @default(NO)
  address            String?
  status             OrderItemStatus @default(BOOKED)
  statusUpdatedAt    DateTime        @default(now())
  statusHistory      OrderItemStatusHistory[]

  // Needed-by, pickup/drop, and address are always stored per item. For
  // one-time delivery the form collects them once and copies them to each item,
  // so the data stays accurate if an order later changes to multiple delivery.
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, sareeNumber])
  @@index([neededBy])
  @@index([pickupDrop])
  @@index([status])
  @@map("order_items")
}

model OrderItemStatusHistory {
  id          String          @id @default(cuid())
  orderItemId String
  status      OrderItemStatus
  changedAt   DateTime        @default(now())
  changedById String

  item      OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  changedBy User      @relation(fields: [changedById], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([changedById])
  @@index([status])
  @@map("order_item_status_history")
}
